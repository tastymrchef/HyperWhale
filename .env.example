# ============================================
# HyperWhale Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Telegram Bot (Phase 3 - optional for now) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Database ---
# Default: SQLite in the data/ folder
# For PostgreSQL: postgresql://user:pass@localhost:5432/hyperwhale
DATABASE_URL=sqlite:///data/hyperwhale.db

# --- Polling ---
# How often to poll whale positions (seconds)
POLL_INTERVAL_TOP_WHALES=30
POLL_INTERVAL_OTHER_WHALES=60

# --- Thresholds ---
# Minimum position size change (%) to trigger an event
MIN_POSITION_CHANGE_PCT=10.0

# Anomaly detection sigma threshold
ANOMALY_SIGMA_THRESHOLD=2.5

# Correlation threshold to flag linked wallets
CORRELATION_THRESHOLD=0.7

# --- Logging ---
LOG_LEVEL=INFO
